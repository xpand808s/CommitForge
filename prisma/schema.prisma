generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  name          String?
  goals         Goal[]
  createdAt     DateTime      @default(now())
  accounts      Account[]
  sessions      Session[]
  settings      UserSetting?
  snapshots     CommitmentSnapshot[]
}

model Goal {
  id            String   @id @default(cuid())
  userId        String
  title         String
  reason        String
  timeline      String
  outcome       String
  createdAt     DateTime @default(now())
  tasks         Task[]
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Task {
  id            String   @id @default(cuid())
  goalId        String
  description   String
  completed     Boolean  @default(false)
  completedAt   DateTime?
  goal          Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)
}

model UserSetting {
  id              String   @id @default(cuid())
  userId          String   @unique
  openAiApiKey    String?
  preferredTheme  String   @default("dark")
  weightedMode    Boolean  @default(false)
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CommitmentSnapshot {
  id              String   @id @default(cuid())
  userId          String
  recordedFor     DateTime
  commitmentValue Float
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, recordedFor])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
